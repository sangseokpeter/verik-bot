# ============================================
# VERI-K Bot - Environment Variables
# Railway에서 설정해야 할 환경변수
# ============================================

# Telegram Bot Token (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# Supabase (database — Storage migrated to Cloudflare R2)
SUPABASE_URL=https://rtaltczlzccupsuzemcj.supabase.co
SUPABASE_SECRET_KEY=

# 관리자 Telegram ID (쉼표로 구분)
ADMIN_IDS=

# OpenAI API Key (TTS용)
OPENAI_API_KEY=

# Anthropic API Key (Claude Sonnet - 퀴즈/듣기 자동 생성)
ANTHROPIC_API_KEY=

# Railway가 자동 설정
PORT=3000

# ============================================
# Cloudflare R2 (object storage — replaces Supabase Storage)
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the R2 bucket (custom domain or r2.dev URL), no trailing slash
# e.g. https://media.verik.app  or  https://pub-<hash>.r2.dev
R2_PUBLIC_BASE_URL=

# ============================================
# Admin notification routing (optional)
# ============================================
# Single admin chat for legacy fallbacks (used by some admin handlers)
ADMIN_CHAT_ID=
# Group chat for admin fan-out (negative chat_id, e.g. -1002383763959)
ADMIN_GROUP_CHAT_ID=
# Dedicated channel for dashboard-action audit logs (falls back to notifyAdmins)
ADMIN_LOG_CHAT_ID=

# ============================================
# Staff dashboard
# ============================================
# Required to enable /dashboard/<TOKEN> routes; if unset, all dashboard routes 404
STAFF_DASHBOARD_TOKEN=
